import scala.io.StdIn

object Addition {
  def main(args: Array[String]): Unit = {
    println("Enter first number:")
    val a = StdIn.readInt()

    println("Enter second number:")
    val b = StdIn.readInt()

    val sum = a + b

    println("Sum = " + sum)
  }
}


scalac Addition.scala//compile
